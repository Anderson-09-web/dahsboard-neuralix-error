{
  "version": 2,
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @workspace/neuralix run build",
  "outputDirectory": "artifacts/neuralix/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "$API_SERVER_URL/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
