{
  "buildCommand": "cd ../.. && pnpm install --no-frozen-lockfile && pnpm --filter @workspace/neuralix run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/api/(.*)",
      "status": 503,
      "headers": { "content-type": "application/json" }
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
